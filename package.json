{
  "name": "ai-augmented-terminal",
  "version": "0.1.0",
  "description": "AI-Augmented multi-tab SSH terminal (Edge Copilot side panel + kubectl-ai style)",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "clean": "rm -rf out dist release",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --x64",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "node-pty": "^1.1.0",
    "openai": "^4.67.3",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/sora": "^5.2.8",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.1",
    "@vitejs/plugin-react": "^4.3.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "zustand": "^4.5.5"
  }
}
